<UserControl x:Class="UniversityMenuApp.Views.TeachersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Mantenimiento de Maestros"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1"
                    Orientation="Vertical"
                    Margin="0,0,0,20"
                    Width="300">

            <TextBlock Text="Name" RenderTransformOrigin="0.5,0.5" Width="208">
                <TextBlock.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="-0.216"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </TextBlock.RenderTransform>
            </TextBlock>

            <TextBox Text="{Binding FormFullName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Email"/>
            <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5,0,0"/>

            <Button Content="Agregar"
                    HorizontalAlignment="Left"
                    Margin="0,25,0,0"
                    VerticalAlignment="Top"
                    Command="{Binding AddTeacherCommand}"/>

            <Button Content="Modificar"
                    HorizontalAlignment="Left"
                    Margin="-4,1,0,0"
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Command="{Binding UpdateTeacherCommand}"/>

            <Button Content="Eliminar"
                    HorizontalAlignment="Left"
                    Margin="0,32,0,0"
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Command="{Binding DeleteTeacherCommand}"/>

        </StackPanel>

        <DataGrid ItemsSource="{Binding Teachers}"
                  SelectedItem="{Binding SelectedTeacher, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  Margin="34,216,34,-69"
                  Grid.Row="1" Grid.RowSpan="2">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="60"/>

                <DataGridTextColumn Header="Name"
                                    Binding="{Binding FullName}"
                                    Width="*"/>

                <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}"
                                    Width="*"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>